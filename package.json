{
  "name": "sidefoot",
  "version": "0.1.0",
  "private": true,
  "description": "Watches TxLINE live odds against on-chain-provable score events and flags the moment the market lags a Merkle-proof-verified stat change.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "record": "tsx src/recordReplay.ts",
    "ingest": "tsx src/runIngest.ts",
    "prove": "tsx src/proveOne.ts",
    "explain": "tsx src/explainOne.ts",
    "start": "tsx src/runPipeline.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@coral-xyz/anchor": "^0.30.1",
    "@herald-protocol/sdk": "^1.9.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "dotenv": "^16.4.5",
    "txline-anchor": "github:unnamed-lab/txline-anchor"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.0.5"
  }
}
