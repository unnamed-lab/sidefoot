# Sidefoot devnet configuration.
# Copy to `.env` and fill in. Never commit `.env`.

# Base58-encoded 64-byte ed25519 secret key of a FUNDED devnet wallet.
# Needs a little devnet SOL for the subscribe + (later) validate transactions.
WALLET_SECRET_KEY=

# Network to run against. Sidefoot is devnet-first; mainnet is out of scope for the MVP.
SIDEFOOT_NETWORK=devnet

# Comma-separated fixture ids to track. Leave blank to stream all fixtures.
# e.g. SIDEFOOT_FIXTURES=1234567,7654321
SIDEFOOT_FIXTURES=

# Where the replay recorder writes its JSONL capture (dir is created if missing).
SIDEFOOT_DATA_DIR=./data

# Reasoning layer (Day 6). Anthropic SDK honours ANTHROPIC_BASE_URL, so this can
# point at Anthropic or any compatible endpoint.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-opus-4-8

# Alerting via Herald (Day 7). Confirmed signals are pushed to a bettor's
# Telegram through Herald's notification gateway.
HERALD_API_KEY=              # hrld_live_xxx (production) or hrld_test_xxx (sandbox)
HERALD_RECIPIENT_WALLET=     # Herald-registered wallet (base58) with Telegram connected
HERALD_RECEIPT=false         # write an on-chain ZK receipt per alert (mainnet + quota)
HERALD_PRIORITY=important    # normal | important | critical
