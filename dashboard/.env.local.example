# TxLINE read credentials for the live API routes (/api/fixtures, /api/feed).
# Generate with `pnpm token` in the sidefoot repo (reads the cached session):
#   cd .. && pnpm token >> dashboard/.env.local
# These are READ-scoped data tokens (guest JWT + API token) — NOT the wallet.
# Without them, the API returns 503 and the dashboard falls back to the
# committed static JSON snapshots.
TXLINE_NETWORK=devnet
TXLINE_JWT=
TXLINE_API_TOKEN=
# Optional origin override (defaults per network).
# TXLINE_ORIGIN=
